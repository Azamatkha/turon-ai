PROJECT_NAME="App service test"
VERSION=0.0.0
DEBUG=false
TESTING=true
TRUST_PROXY_HEADERS=True
LOCAL_TIMEZONE=UTC

# Logging
LOG_LEVEL=INFO
LOG_LEVEL_FILE=WARNING

# CORS
CORS_ALLOWED_ORIGINS=["*"]
CORS_ALLOWED_CREDENTIALS=true
CORS_ALLOWED_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOWED_HEADERS=["*"]
CORS_EXPOSE_HEADERS=["*"]

# SQL Database (use test DB or ephemeral)
DB_ECHO=0
POSTGRES_USER=test
POSTGRES_PASSWORD=test
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=test_db

# Redis
REDIS_HOST=localhost
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_CELERY_DATABASE=1

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# JWT Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_USED_TTL_SECONDS=1800
VERIFICATION_TOKEN_EXPIRE_MINUTES=30
RESET_PASSWORD_TOKEN_EXPIRE_MINUTES=30

# JWT Secret keys
PROJECT_SECRET_KEY=test-project-secret-key-not-real
JWT_USER_SECRET_KEY=test-jwt-user-secret-key-not-real
JWT_ADMIN_SECRET_KEY=test-jwt-admin-secret-key-not-real
JWT_VERIFY_SECRET_KEY=test-jwt-verify-secret-key-not-real
JWT_RESET_PASSWORD_SECRET_KEY=test-jwt-reset-secret-key-not-real

# Admin app credentials
SUPER_ADMIN_USERNAME=admin_test
SUPER_ADMIN_PASSWORD=test_password
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PHONE=+10000000000

# Email (dummy)
EMAIL_SERVER=localhost
EMAIL_PORT=1025
EMAIL_PASSWORD=
EMAIL_USER=test@example.com
EMAIL_FROM=test@example.com
EMAIL_FROM_NAME=test
EMAIL_USE_TLS=False
EMAIL_STARTTLS=False
VALIDATE_CERTS=False

# WebSocket
PING_INTERVAL=55
CONNECTION_TTL=220

# AI Settings
AI_PROVIDER=gemini
GEMINI_API_KEY=key
GEMINI_MODEL=gemini-2.5-flash-lite
ANTHROPIC_API_KEY=key
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_FALLBACK_MODELS=claude-sonnet-4-6,claude-haiku-4-5
TIMEOUT_SECONDS=30
MAX_RETRIES=2
DEFAULT_TEMPERATURE=0.2
DEFAULT_MAX_TOKENS=700

APP_BACKEND_PORT=8001
